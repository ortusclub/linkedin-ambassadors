generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  active
  suspended
  deleted
}

enum UserRole {
  customer
  admin
}

enum AccountStatus {
  under_review
  available
  rented
  maintenance
  unavailable
  retired
  removed
}

enum RentalStatus {
  active
  expired
  cancelled
  payment_failed
  pending_access
}

model User {
  id                String     @id @default(uuid()) @db.Uuid
  email             String     @unique
  passwordHash      String?    @map("password_hash")
  fullName          String     @map("full_name")
  role              UserRole   @default(customer)
  stripeCustomerId  String?    @unique @map("stripe_customer_id")
  status            UserStatus @default(active)
  emailVerified     DateTime?  @map("email_verified")
  contactNumber     String?    @map("contact_number")
  company           String?    @map("company")
  industry          String?    @map("industry")
  image             String?
  usdcBalance       Decimal    @default(0) @map("usdc_balance") @db.Decimal(18, 6)
  dismissAppModalUntil DateTime? @map("dismiss_app_modal_until")
  paymentDetails    String?    @map("payment_details")
  referralSource    String?    @map("referral_source")
  vettingStartedAt  DateTime?  @map("vetting_started_at") // opened the vetting form at checkout (for drop-off tracking)
  vettedAt          DateTime?  @map("vetted_at")      // renter vetting completed + agreed to use policy
  vettingInfo       Json?      @map("vetting_info")   // { company, website, role, useCase, tools }
  vettingReview     String?    @map("vetting_review") // admin's personal check: pending | verified | flagged
  stripePaymentMethodId String? @map("stripe_payment_method_id")
  cardBrand         String?    @map("card_brand")
  cardLast4         String?    @map("card_last4")
  isTest            Boolean    @default(false) @map("is_test")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  rentals           Rental[]
  waitlistEntries   Waitlist[]
  sessions          Session[]
  transactions      Transaction[]
  depositAddress    DepositAddress?

  @@map("users")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  token        String   @unique
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationCode {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  codeHash  String   @map("code_hash")
  expiresAt DateTime @map("expires_at")
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("verification_codes")
}

model LinkedInAccount {
  id                    String        @id @default(uuid()) @db.Uuid
  gologinProfileId      String?       @map("gologin_profile_id")
  // Which GoLogin account hosts this profile: "master" (info@ortus, legacy rentals)
  // or "klabber" (info@klabber.co, all new inventory). Picks the API token to use.
  gologinAccount        String        @default("master") @map("gologin_account")
  linkedinName          String        @map("linkedin_name")
  linkedinHeadline      String?       @map("linkedin_headline")
  linkedinUrl           String?       @map("linkedin_url")
  connectionCount       Int           @default(0) @map("connection_count")
  industry              String?
  location              String?
  profileScreenshotUrl  String?       @map("profile_screenshot_url")
  profilePhotoUrl       String?       @map("profile_photo_url")
  proxyHost             String?       @map("proxy_host")
  proxyPort             Int?          @map("proxy_port")
  proxyUsername         String?       @map("proxy_username")
  proxyPassword         String?       @map("proxy_password")
  status                AccountStatus @default(available)
  monthlyPrice          Decimal       @default(0) @map("monthly_price") @db.Decimal(10, 2)
  ambassadorPayment     Decimal       @default(0) @map("ambassador_payment") @db.Decimal(10, 2)
  accountAgeMonths      Int?          @map("account_age_months")
  hasSalesNav           Boolean       @default(false) @map("has_sales_nav")
  listed                Boolean       @default(true)
  gologinShareLink      String?       @map("gologin_share_link")
  linkedinAccountHealth String?       @default("unchecked") @map("linkedin_account_health")
  healthCheckedAt       DateTime?     @map("health_checked_at")
  restrictedAt          DateTime?     @map("restricted_at")  // admin-set: account restricted by LinkedIn, recovering
  // Internal proof the account is real (email-exchange screenshot links / notes).
  // Never shown publicly — shared with a renter per-case.
  verificationProof     String?       @map("verification_proof")
  linkedinVerified      Boolean       @default(false) @map("linkedin_verified")
  notes                 String?
  removedAt             DateTime?     @map("removed_at")
  removedBy             String?       @map("removed_by")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  rentals               Rental[]
  waitlistEntries       Waitlist[]

  @@map("linkedin_accounts")
}

model Rental {
  id                    String       @id @default(uuid()) @db.Uuid
  userId                String       @map("user_id") @db.Uuid
  linkedinAccountId     String       @map("linkedin_account_id") @db.Uuid
  stripeSubscriptionId  String?      @unique @map("stripe_subscription_id")
  startDate             DateTime     @default(now()) @map("start_date")
  currentPeriodEnd      DateTime?    @map("current_period_end")
  autoRenew             Boolean      @default(true) @map("auto_renew")
  status                RentalStatus @default(active)
  accessGrantedAt       DateTime?    @map("access_granted_at")
  usdcPayment           Boolean      @default(false) @map("usdc_payment")
  // Per-rental price lock: when set, billing charges this instead of the account's
  // current listed price. Lets us raise catalogue prices while grandfathering existing
  // renters at their original rate (e.g. Nico locked at $50 while inventory lists $75).
  lockedPrice           Decimal?     @map("locked_price") @db.Decimal(10, 2)
  accessRevokedAt       DateTime?    @map("access_revoked_at")
  paused                Boolean      @default(false)
  // GoLogin shares created for this rental, so we can revoke them on pause:
  // [{ email, shareId }] — LEGACY email-share method (kept for backward compat).
  gologinShareIds       Json         @default("[]") @map("gologin_share_ids")
  // Current public g.camp share link for this rental (the access mechanism).
  // linkId = GoLogin _id used to pause/delete; url = full openable g.camp link.
  // Regenerated per rental; deleted (and cleared) on revoke/expire/end.
  gologinShareLinkId    String?      @map("gologin_share_link_id")
  gologinShareLinkUrl   String?      @map("gologin_share_link_url")
  // Admin-only tracker fields (match the internal Renter sheet).
  campaignGoal          String?      @map("campaign_goal")
  // LinkedVelocity point of contact — who owns this renter relationship.
  lvPoc                 String?      @map("lv_poc")
  // Which renewal-cadence emails have fired this cycle (e.g. ["reminder_3d","grace"]);
  // cleared on renewal. Prevents duplicate sends from the daily cron.
  renewalRemindersSent  Json         @default("[]") @map("renewal_reminders_sent")
  // Auto-grant retry counter: how many times the cron has tried to share GoLogin
  // access (the renter must have set up GoLogin first). Bounded to avoid looping.
  accessGrantAttempts   Int          @default(0) @map("access_grant_attempts")
  notes                 String?
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  user                  User            @relation(fields: [userId], references: [id])
  linkedinAccount       LinkedInAccount @relation(fields: [linkedinAccountId], references: [id])
  transactions          Transaction[]

  @@map("rentals")
}

model Waitlist {
  id                String          @id @default(uuid()) @db.Uuid
  userId            String          @map("user_id") @db.Uuid
  linkedinAccountId String          @map("linkedin_account_id") @db.Uuid
  createdAt         DateTime        @default(now()) @map("created_at")

  user              User            @relation(fields: [userId], references: [id])
  linkedinAccount   LinkedInAccount @relation(fields: [linkedinAccountId], references: [id])

  @@unique([userId, linkedinAccountId])
  @@map("waitlist")
}

enum AmbassadorStatus {
  pending
  reviewing
  approved
  rejected
  onboarded
  unreachable
  contacted
  on_hold
}

model AmbassadorApplication {
  id                String           @id @default(uuid()) @db.Uuid
  fullName          String           @map("full_name")
  email             String
  linkedinEmail     String?          @map("linkedin_email")
  contactNumber     String?          @map("contact_number")
  linkedinUrl       String           @map("linkedin_url")
  connectionCount   Int?             @map("connection_count")
  industry          String?
  location          String?
  notes             String?
  referralSource    String?          @map("referral_source")
  referredBy        String?          @map("referred_by")
  status            AmbassadorStatus @default(pending)
  offeredAmount     Decimal?         @map("offered_amount") @db.Decimal(10, 2)
  adminNotes        String?          @map("admin_notes")
  paymentMethod     String?          @map("payment_method")
  bankName          String?          @map("bank_name")
  bankAccountName   String?          @map("bank_account_name")
  bankAccountNumber String?          @map("bank_account_number")
  bankRoutingNumber String?          @map("bank_routing_number")
  bankSortCode      String?          @map("bank_sort_code")
  usdcWalletAddress String?          @map("usdc_wallet_address")
  usdcNetwork       String?          @map("usdc_network")
  paypalEmail       String?          @map("paypal_email")
  wiseEmail         String?          @map("wise_email")
  poc               String?          @map("poc")
  outreachLog       Json?            @map("outreach_log")
  nextFollowUp      DateTime?        @map("next_follow_up")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  @@map("ambassador_applications")
}

// A field marketer / ambassador who refers signups. `slug` is the ?ref= value in
// their QR; `token` is the secret for their portal link /m/<token>. Self-editable
// fields (contact, payment) are filled by them via the portal.
model Referrer {
  id               String   @id @default(uuid()) @db.Uuid
  slug             String   @unique
  token            String   @unique
  name             String
  type             String   @default("marketer")
  channel          String?
  contactMethod    String?  @map("contact_method")
  contactHandle    String?  @map("contact_handle")
  paymentMethod    String?  @map("payment_method")
  paymentDetails   String?  @map("payment_details")
  assignedDay      String?  @map("assigned_day")
  assignedLocation String?  @map("assigned_location")
  active           Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("referrers")
}

enum TransactionType {
  deposit
  rental_payment
  sweep
  refund
  adjustment
}

model DepositAddress {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @unique @map("user_id") @db.Uuid
  address          String   @unique
  derivationIndex  Int      @unique @map("derivation_index")
  lastSeenBalance  Decimal  @default(0) @map("last_seen_balance") @db.Decimal(18, 6)
  createdAt        DateTime @default(now()) @map("created_at")

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("deposit_addresses")
}

model Transaction {
  id          String          @id @default(uuid()) @db.Uuid
  userId      String          @map("user_id") @db.Uuid
  type        TransactionType
  amount      Decimal         @db.Decimal(18, 6)
  txHash      String?         @map("tx_hash")
  rentalId    String?         @map("rental_id") @db.Uuid
  description String?
  createdAt   DateTime        @default(now()) @map("created_at")

  user        User            @relation(fields: [userId], references: [id])
  rental      Rental?         @relation(fields: [rentalId], references: [id])

  @@map("transactions")
}

// Inbound leads — people who proactively reach out (Telegram messages, call
// bookings). One row per person per channel (upserted). Powers the live
// "Inbound" admin tab + Google Sheet. Signups/customers live elsewhere (not inbound).
model InboundLead {
  id             String   @id @default(uuid()) @db.Uuid
  channel        String                                  // platform: "telegram" | "website" | "call" | ...
  name           String                                  // name or @username
  handle         String?                                 // @username (telegram)
  contact        String?                                 // telegram chat id (internal dedup key)
  companyEmail   String?  @map("company_email")           // their company / email
  type           String?                                 // "Potential Renter" | "Potential Ambassador" | ...
  message        String?                                 // use case / latest message
  status         String   @default("new")
  replied        Boolean  @default(false)
  followUpDate   DateTime? @map("follow_up_date")
  outcome        String?
  source         String?
  notes          String?
  stage          String   @default("new")                    // CRM pipeline: new | warm | active | cold | lost
  ownerEmail     String?  @map("owner_email")                 // who on the team owns this relationship
  commsLog       Json?    @map("comms_log")                   // timestamped touchbase timeline: [{ ts, channel, body }]
  messageCount   Int      @default(1)  @map("message_count")
  firstContactAt DateTime @default(now()) @map("first_contact_at")
  lastContactAt  DateTime @default(now()) @map("last_contact_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([channel, contact])
  @@map("inbound_leads")
}

model BlogPost {
  id            String    @id @default(uuid()) @db.Uuid
  slug          String    @unique
  title         String
  description   String    @default("")
  category      String    @default("LinkedIn Strategy")
  priority      String    @default("P2")                   // idea priority: P1 | P2 | P3
  keyword       String?                                    // target SEO keyword
  pillar        String?                                    // content pillar
  content       String    @default("")                     // markdown body
  readTime      String?   @map("read_time")
  status        String    @default("draft")                // draft | in_review | approved | published
  scheduledFor  DateTime? @map("scheduled_for")            // calendar / target publish date
  publishedAt   DateTime? @map("published_at")
  authorEmail   String?   @map("author_email")
  reviewerNotes String?   @map("reviewer_notes")           // Sam's review feedback
  linkedinPost     String?   @map("linkedin_post")         // repurposed LinkedIn caption (optional)
  linkedinPostedAt DateTime? @map("linkedin_posted_at")    // when it was shared to LinkedIn
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("blog_posts")
}

// One row per calendar day: a snapshot of the headline run-rate metrics, so the
// dashboard can show past months + month-over-month trends. Written by the
// /api/cron/snapshot-metrics daily cron. Only starts from the day it's turned on
// (no historical backfill is possible — we never recorded it before).
model MetricsSnapshot {
  id                 String   @id @default(uuid()) @db.Uuid
  date               DateTime @unique @db.Date
  mrr                Float    @default(0)
  netProfit          Float    @default(0) @map("net_profit")
  payouts            Float    @default(0)
  activeRentals      Int      @default(0) @map("active_rentals")
  totalCustomers     Int      @default(0) @map("total_customers")
  totalAccounts      Int      @default(0) @map("total_accounts")
  availableAccounts  Int      @default(0) @map("available_accounts")
  rentedAccounts     Int      @default(0) @map("rented_accounts")
  offlineAccounts    Int      @default(0) @map("offline_accounts")
  restrictedAccounts Int      @default(0) @map("restricted_accounts")
  utilization        Int      @default(0)
  createdAt          DateTime @default(now()) @map("created_at")

  @@map("metrics_snapshots")
}
