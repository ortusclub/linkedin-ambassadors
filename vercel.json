{
  "buildCommand": "npx prisma migrate deploy && npx prisma generate && npm run build",
  "framework": "nextjs",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/detect-deposits",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/process-renewals",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/auto-grant",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/snapshot-metrics",
      "schedule": "55 23 * * *"
    }
  ]
}
