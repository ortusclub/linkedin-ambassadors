{
  "name": "klabber",
  "version": "1.0.2",
  "description": "Klabber — Secure browser for ambassador account login",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win"
  },
  "build": {
    "appId": "co.klabber.ambassador",
    "productName": "Klabber",
    "files": [
      "main.js",
      "preload.js",
      "fingerprint.js",
      "index.html",
      "styles.css",
      ".puppeteerrc.cjs",
      ".chromium/**/*",
      "node_modules/puppeteer/**/*",
      "node_modules/puppeteer-core/**/*",
      "node_modules/@puppeteer/**/*"
    ],
    "asarUnpack": [
      ".chromium/**/*",
      "node_modules/@puppeteer/**/*"
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": "dmg",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": "nsis"
    }
  },
  "type": "commonjs",
  "dependencies": {
    "proxy-chain": "^2.7.1",
    "puppeteer": "^24.9.0"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  }
}
